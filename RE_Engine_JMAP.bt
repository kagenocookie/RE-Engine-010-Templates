//------------------------------------------------
//--- 010 Editor v9.0.2 Binary Template
//
//      File: RE_Engine_jmap.bt
//   Authors: alphaZomega, shadowcookie
//   Version: 0.3
//   Purpose: Parsing RE Engine jmap files
//  Category: RE Engine
// File Mask: *.jmap.*
//  ID Bytes:
//   History: Oct 10, 2022
//------------------------------------------------


LittleEndian();
SetForeColor(cGreen);

#include "common.bt";
local uint i <hidden=1>;

struct {
    uint version;
    uint magic;
    FSkip(8);
    if (version <= 11) { //dmc5/re2
	    uint64 bonesOffset;
	    uint64 afterBonesOffs;
    }
    uint64 jointMaskGroupTbl;
    uint64 jointExGroupDataPtr;
    uint64 extraJointDataPtr;

    if (version <= 11) { //dmc5/re2
	    ushort boneCount;
        ushort jointMaskGroupCount;
        ushort extraJointsCount;
        FSkip(2);
    } else {
        uint64 ikMotionDataPtr;
        uint64 symmetryMirrorDataPtr;
        if (version >= 19)
            uint64 extraHashesPtr;
        if (version >= 28) {
            uint64 uknPtr;
            uint64 uknPtr;
            uint64 uknPtr;
            uint64 uknPtr;
            uint64 uknPtr;
            uint64 uknPtr;
        }
        uint32 AttributeFlags;
        uint16 jointMaskGroupCount;
    }
} Header;

if (Header.version <= 11) {
    struct {
        struct {
            vec3p offset;
            vec4 rotation;
            uint16 parent;
            uint16 null;
            uint32 boneHash;
            FSkip (8);
        } BONES[Header.boneCount] <optimize=false>;
    } BONES;

    FSeek(Header.afterBonesOffs);
    struct {
        uint64 ukn1Offs;
        uint32 ukn[10];
        FSeek(ukn1Offs);
        uint32 ukn1[60];
    } AFTERBONES;
}

FSeek(Header.jointMaskGroupTbl);
if (Header.jointMaskGroupTbl && Header.jointMaskGroupCount) {
    struct {
        struct {
            uint64 jointNameHashTbl;
            uint64 maskTbl;
            if (Header.version >= 17) {
                uint64 weightTbl;
            }
            uint32 groupID;
            uint16 jointCount;
            uint16 empty;
            FSeek(jointNameHashTbl);
            if (jointNameHashTbl)
                uint jointHash[jointCount];
            FSeek(maskTbl);
            if (maskTbl)
                uchar mask[jointCount];
            if (exists(weightTbl)) {
                FSeek(weightTbl);
                if (weightTbl)
                    float weight[jointCount];
            }
            FSeek(startof(empty)+2);
        } jointMaskGroup[Header.jointMaskGroupCount] <optimize=false>;
    } jointMaskGroups;
}

enum <ubyte> JointExType
{
    JointExType_None = 0,
    JointExType_Rotation = 1,
    JointExType_RotToScale = 2,
    JointExType_RotToScaleEx = 3,
    JointExType_RotToTrans = 4,
    JointExType_RotToTransEx = 5,
    JointExType_Finger = 6,
    JointExType_Thumb = 7,
    JointExType_RotToRot = 8,
    JointExType_RotToRotEx = 9,
    JointExType_Limit = 10,
    JointExType_PointConstraint = 11,
    JointExType_ParentConstraint = 12,
    JointExType_BsplineConstraint = 13,
    JointExType_RemapValue = 14,
    JointExType_MultiRemapValue = 15,
    JointExType_Rotation2 = 16,
};

FSeek(Header.jointExGroupDataPtr);
if (Header.jointExGroupDataPtr) {
    struct {
        uint64 jointExTypeTbl;
        uint64 jointExLodTbl;
        uint64 jointExDataPtrTbl;
        uint32 count;
        if (count) {
            FSeek(jointExTypeTbl);
            if (jointExTypeTbl)
                JointExType jointExType[count];
            FSeek(jointExLodTbl);
            if (jointExLodTbl)
                uchar jointExLod[count];
            FSeek(jointExDataPtrTbl);
            if (jointExDataPtrTbl)
                uint64 jointExDataPtr[count];

            struct  {
                for (i = 0; i < count; ++i) {
                    FSeek(jointExDataPtr[i]);
                    struct {
                        local JointExType itemType = jointExType[i];
                        if (itemType == 1) {
                            uint32 hash;
                            uint32 hash2;
                            ubyte flags;
                            ubyte uknNum;
                            uint16 null;
                            vec3 rotation;
                        } else if (itemType == 4) {
                            uint32 hash;
                            uint hash2;
                            uint num;
                            uint flags;
                            uint data[24];
                        } else if (itemType == 5) {
                            uint32 hash;
                            uint hash2;
                            uint num;
                            uint flags;
                            uint data[36];
                        } else if (itemType == 6) {
                            uint32 hash;
                            uint num;
                            uint hash2;
                            uint flags;
                            uint data[88];
                        } else if (itemType == 7) {
                            uint32 hash;
                            uint num;
                            uint hash2;
                            uint flags;
                            uint data[76];
                        } else if (itemType == 9) {
                            uint32 hash;
                            uint hash2;
                            uint num;
                            uint flags;
                            uint data[36];
                        } else if (itemType == 14) {
                            uint32 hash;
                            uint data[51];
                        } else if (itemType == 16) {
                            vec4 q1;
                            vec4 q2;
                            uint hash1;
                            uint hash2;
                            uint ukn;
                            vec3 vec;
                        }
                    } JointExItem <read=Str("type = %d", itemType)>;
                }
            } JointExData;
        }

    } jointExGroupData;
}

FSeek(Header.extraJointDataPtr);
if (Header.extraJointDataPtr) {
    struct {
        uint64 extraJointTbl;
        uint32 extraJointCount;
        if (extraJointCount && extraJointTbl) {
            FSeek(extraJointTbl);
            for(i=0; i<extraJointCount; i++) {
                struct extraJoint {
                    OffsetWString parentName(0);
                    OffsetWString jointName(0);
                    uint32 parentNameHash;
                    uint32 jointNameHash;
                    uint32 symmetryNameHash;
                    uint16 attrFlags;
                    uint16 padding;
                    if (Header.version >= 19)
                        uint64 ukn;
                } ExtraJoint <read=ReadExtraJoint>;
            }
        }
    } extraJoints;
}

if (exists(Header.ikMotionDataPtr)) {
    FSeek(Header.ikMotionDataPtr);
    if (Header.ikMotionDataPtr && Header.ikMotionDataPtr < FileSize()) {
        uint32 ikJointNameHash;
        uint32 fkJointNameHash;
        byte ikType;
        char descendantLevelFromIkHandle;
        byte ikDirection;
        byte ikUpvector;
    }
}

if (exists(Header.symmetryMirrorDataPtr)) {
    FSeek(Header.symmetryMirrorDataPtr);
    if (Header.symmetryMirrorDataPtr && Header.symmetryMirrorDataPtr < FileSize()) {
        struct symmetryMirrorData {
            uint64 mirrorJointHashTbl;
            uint64 mirrorTbl;
            int mirrorTblCount;

            FSeek(mirrorJointHashTbl);
            if (mirrorJointHashTbl) {
                uint mirrorJointHash[mirrorTblCount];
            }

            FSeek(mirrorTbl);
            if (mirrorTbl) {
                struct {
                    ubyte one, two;
                } Pairs[mirrorTblCount] <read=Str("%d %d", one, two)>;
            }
        } SymmetryMirrorData;
    }
}
if (exists(Header.extraHashesPtr) && Header.extraHashesPtr) {
    FSeek(Header.extraHashesPtr);
    struct {
        uint64 dataOffset;
        uint32 count;
        uint32 hashes[count];
    } extraHashData;
}

wstring ReadExtraJoint(extraJoint &e) {
    return e.parentName.str + " -> " + e.jointName.str;
}